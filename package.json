{
  "name": "azure-wiki-edit",
  "productName": "AzureWikiEdit",
  "version": "1.0.0",
  "description": "Desktop WYSIWYG editor for Azure DevOps Wiki markdown files",
  "main": ".webpack/main",
  "scripts": {
    "start": "electron-forge start",
    "start:prod": "cross-env PROD_BUILD=true electron-forge start",
    "package": "electron-forge package",
    "package:prod": "cross-env PROD_BUILD=true electron-forge package",
    "make": "electron-forge make",
    "make:prod": "cross-env PROD_BUILD=true electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "test:visual": "node tests/visual-editor/test-runner.js",
    "postinstall": "patch-package"
  },
  "keywords": [
    "electron",
    "markdown",
    "azure-devops",
    "wiki",
    "editor"
  ],
  "author": "MajorComputing",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.4.0",
    "@electron-forge/maker-deb": "^7.4.0",
    "@electron-forge/maker-rpm": "^7.4.0",
    "@electron-forge/maker-squirrel": "^7.4.0",
    "@electron-forge/maker-zip": "^7.4.0",
    "@electron-forge/plugin-auto-unpack-natives": "^7.4.0",
    "@electron-forge/plugin-webpack": "^7.4.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "cross-env": "^7.0.3",
    "css-loader": "^6.10.0",
    "electron": "^29.0.0",
    "node-loader": "^2.0.0",
    "patch-package": "^8.0.1",
    "puppeteer": "^24.35.0",
    "style-loader": "^3.3.4"
  },
  "dependencies": {
    "@jsplumb/browser-ui": "^6.2.10",
    "@lancedb/lancedb": "^0.23.0",
    "@lancedb/lancedb-win32-x64-msvc": "^0.23.0",
    "@langchain/anthropic": "^1.3.10",
    "@langchain/core": "^1.1.15",
    "@langchain/google-genai": "^2.1.10",
    "@langchain/openai": "^1.2.2",
    "@toast-ui/editor": "^3.2.2",
    "@toast-ui/editor-plugin-code-syntax-highlight": "^3.1.0",
    "@toast-ui/editor-plugin-color-syntax": "^3.1.0",
    "apache-arrow": "^18.1.0",
    "dagre": "^0.8.5",
    "diff": "^8.0.3",
    "dotenv": "^17.2.3",
    "electron-squirrel-startup": "^1.0.1",
    "ffmpeg-static": "^5.2.0",
    "ignore": "^7.0.5",
    "langchain": "^1.2.10",
    "marked": "^17.0.1",
    "mermaid": "^10.9.0",
    "pdfjs-dist": "^4.4.168",
    "prismjs": "^1.29.0",
    "sharp": "^0.33.5",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.26.3"
  }
}
